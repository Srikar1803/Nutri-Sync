# ─────────────────────────────────────────────────────────────
# NutriSync — Environment Variables Template
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit your .env file to Git.
# ─────────────────────────────────────────────────────────────

# ── REQUIRED ─────────────────────────────────────────────────

# Groq API key — get free at https://console.groq.com
# Click: API Keys → Create API Key
GROQ_API_KEY=gsk_YOUR_KEY_HERE

# ── OPTIONAL: File Paths ──────────────────────────────────────
# Defaults are shown. Only set these if your files are elsewhere.

# USDA nutrition CSV (tracked in Git under backend/data/)
# USDA_CSV_PATH=data/usda_nutrition_processed.csv

# FAISS index file (download separately — not in Git)
# FAISS_INDEX_PATH=data/recipe_index.faiss

# Recipe SQLite database (download separately — not in Git)
# RECIPE_DB_PATH=data/recipes.db

# ── OPTIONAL: Google Health Connect OAuth2 ───────────────────
# Leave blank to use mock wearable mode (recommended for local dev)
# Only needed for the live Android Google Health Connect integration

# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# ── OPTIONAL: Rate Limiting ───────────────────────────────────
# Seconds to wait between Groq calls during batch evaluation
# Increase to 2.5 if you hit 429 rate limit errors
# BATCH_DELAY=2.0

# ── OPTIONAL: Server Config ──────────────────────────────────
# HOST=0.0.0.0
# PORT=8000
# DEBUG=true
